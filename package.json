{
  "name": "krill-bill",
  "version": "0.1.0",
  "private": true,
  "description": "Krill Bill: invoice manager SaaS (local-first) built as a Vite React SPA.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,html,yml,yaml}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terrarium-labs/krill-bill.git"
  },
  "homepage": "https://github.com/terrarium-labs/krill-bill#readme",
  "bugs": {
    "url": "https://github.com/terrarium-labs/krill-bill/issues"
  },
  "keywords": [
    "krill-bill",
    "invoice",
    "saas",
    "react",
    "vite",
    "cloudflare-pages",
    "bun"
  ],
  "author": {
    "name": "@xarlizard",
    "email": "38315638+xarlizard@users.noreply.github.com",
    "url": "https://github.com/xarlizard"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.2.15",
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.0"
  }
}
